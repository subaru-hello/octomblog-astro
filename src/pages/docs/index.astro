---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocsSidebar from '../../components/docs/DocsSidebar.astro';

const allDocs = await getCollection('docs');
const categories = ['概念', 'フレームワーク', 'Tips'] as const;

// シリーズ一覧（件数付き）
const seriesCount: Record<string, number> = {};
allDocs.forEach((doc) => {
  doc.data.series?.forEach((s) => {
    seriesCount[s] = (seriesCount[s] ?? 0) + 1;
  });
});
const allSeries = Object.entries(seriesCount).sort((a, b) => b[1] - a[1]);

const grouped = categories.map((cat) => ({
  label: cat,
  docs: allDocs
    .filter((d) => d.data.category === cat)
    .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0) || a.data.title.localeCompare(b.data.title, 'ja')),
}));

const categoryColors: Record<string, string> = {
  '概念': 'var(--badge-tech)',
  'フレームワーク': 'var(--badge-idea)',
  'Tips': 'var(--badge-tips)',
};
---

<BaseLayout title="Docs" noContainer>
  <div class="flex min-h-screen">
    <!-- モバイル：オーバーレイ背景 -->
    <div
      id="sidebar-backdrop"
      class="fixed inset-0 z-30 bg-black/50 hidden lg:hidden"
      aria-hidden="true"
    ></div>

    <!-- 左サイドバー（lg以上：固定表示 / モバイル：ドロワー） -->
    <aside
      id="docs-sidebar"
      class="
        fixed top-14 left-0 z-40 h-[calc(100vh-3.5rem)] w-64
        -translate-x-full transition-transform duration-200
        lg:sticky lg:top-14 lg:translate-x-0 lg:w-56 lg:shrink-0 lg:block lg:z-auto
        border-r border-[var(--border)] bg-[var(--sidebar-bg)]
      "
    >
      <div class="h-full overflow-y-auto scrollbar-none p-4">
        <p class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest mb-4">Docs</p>
        <DocsSidebar />
      </div>
    </aside>

    <!-- 中央コンテンツ -->
    <div class="flex-1 min-w-0 px-6 py-8">
      <div class="max-w-6xl mx-auto">
        <!-- モバイル：サイドバー開閉ボタン -->
        <button
          id="sidebar-toggle"
          class="lg:hidden flex items-center gap-1.5 text-xs text-[var(--text-muted)] hover:text-[var(--text-primary)] mb-4 transition-colors"
          aria-label="サイドバーを開く"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          メニュー
        </button>

        <div class="mb-8">
          <h1 class="text-2xl font-bold text-[var(--text-primary)] mb-1">Docs</h1>
          <p class="text-sm text-[var(--text-secondary)]">
            読んだ本・文献から抽出した概念・フレームワーク・Tipsをまとめています
          </p>
        </div>

        <!-- シリーズフィルター -->
        {allSeries.length > 0 && (
          <div class="mb-8">
            <h2 class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider mb-2">シリーズ</h2>
            <div class="flex flex-wrap gap-2">
              {allSeries.map(([name, count]) => (
                <a
                  href={`/docs/series/${encodeURIComponent(name)}`}
                  class="inline-flex items-center gap-1.5 px-3 py-1 text-xs rounded-full border border-[var(--border)] text-[var(--text-secondary)] bg-[var(--bg-secondary)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors"
                >
                  📚 {name} <span class="text-[var(--text-muted)]">{count}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        {grouped.map(({ label, docs }) => docs.length > 0 && (
          <section class="mb-10">
            <div class="flex items-center gap-2 mb-4">
              <span
                class="text-xs font-bold px-2.5 py-0.5 rounded-full text-white"
                style={`background-color: ${categoryColors[label]};`}
              >
                {label}
              </span>
              <span class="text-xs text-[var(--text-muted)]">{docs.length}件</span>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
              {docs.map((doc) => (
                <a
                  href={`/docs/${doc.id}`}
                  class="group p-4 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:border-[var(--accent)] transition-all hover:shadow-sm"
                >
                  <div class="flex items-start gap-2">
                    <span class="text-2xl shrink-0 leading-tight">{doc.data.emoji}</span>
                    <div class="min-w-0">
                      <h2 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors leading-snug mb-1">
                        {doc.data.title}
                      </h2>
                      {doc.data.description && (
                        <p class="text-xs text-[var(--text-muted)] line-clamp-2 leading-relaxed">{doc.data.description}</p>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}

        {allDocs.length === 0 && (
          <p class="text-sm text-[var(--text-muted)]">まだドキュメントがありません。</p>
        )}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const toggle   = document.getElementById('sidebar-toggle');
  const sidebar  = document.getElementById('docs-sidebar');
  const backdrop = document.getElementById('sidebar-backdrop');

  function openSidebar() {
    sidebar?.classList.remove('-translate-x-full');
    backdrop?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    sidebar?.classList.add('-translate-x-full');
    backdrop?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openSidebar);
  backdrop?.addEventListener('click', closeSidebar);
</script>
