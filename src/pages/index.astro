---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileHeader from '../components/home/ProfileHeader.astro';
import ArticleCard from '../components/home/ArticleCard.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const allDocs = await getCollection('docs');
const recentDocs = allDocs
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const skills = ['TypeScript', 'React', 'Go', 'Python', 'Node.js', 'Cloudflare'];

const projects = [
  { name: 'NearRun', desc: 'ランナー向けサービス', tech: 'React / TypeScript / Firebase', href: 'https://github.com/subaru-hello' },
  { name: 'kakuStudy', desc: '学習管理アプリ', tech: 'React / TypeScript', href: 'https://github.com/subaru-hello' },
  { name: 'just-coding', desc: 'LeetCode解答集', tech: 'C++ / Python', href: 'https://github.com/subaru-hello/just-coding' },
  { name: 'cloudflare-anything', desc: 'Cloudflare統合実験', tech: 'Cloudflare Workers', href: 'https://github.com/subaru-hello' },
];
---

<BaseLayout title="Home">
  <div class="max-w-4xl mx-auto">
    <!-- プロフィール -->
    <ProfileHeader />

    <!-- スキル -->
    <section class="mb-12">
      <h2 class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest mb-3">Skills</h2>
      <div class="flex flex-wrap gap-2">
        {skills.map((skill) => (
          <span class="px-3 py-1 text-xs rounded-full border border-[var(--border)] text-[var(--text-secondary)] bg-[var(--bg-secondary)]">
            {skill}
          </span>
        ))}
      </div>
    </section>

    <!-- プロジェクト -->
    <section class="mb-12">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest">Projects</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {projects.map(({ name, desc, tech, href }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="p-4 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:border-[var(--accent)] transition-all group"
          >
            <div class="flex items-start justify-between gap-2">
              <div>
                <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors">{name}</h3>
                <p class="text-xs text-[var(--text-secondary)] mt-0.5">{desc}</p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--text-muted)] shrink-0 mt-0.5 group-hover:text-[var(--accent)] transition-colors">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </div>
            <p class="text-xs text-[var(--text-muted)] mt-2">{tech}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Docs -->
    <section class="mb-12">
      <div class="flex items-center justify-between mb-1">
        <h2 class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest">Docs</h2>
        <a href="/docs" class="text-xs text-[var(--accent)] hover:underline">すべて見る →</a>
      </div>
      <p class="text-xs text-[var(--text-muted)] mb-4">読んだ本・記事から学んだ概念などをまとめています</p>
      {recentDocs.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          {recentDocs.map((doc) => (
            <a
              href={`/docs/${doc.id}`}
              class="group p-4 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] hover:border-[var(--accent)] transition-all hover:shadow-sm"
            >
              <div class="flex items-start gap-2">
                <span class="text-xl shrink-0 leading-tight">{doc.data.emoji}</span>
                <div class="min-w-0">
                  <h3 class="text-sm font-semibold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors leading-snug mb-1 line-clamp-2">
                    {doc.data.title}
                  </h3>
                  {doc.data.description && (
                    <p class="text-xs text-[var(--text-muted)] line-clamp-2 leading-relaxed">{doc.data.description}</p>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm text-[var(--text-muted)]">ドキュメントがありません。</p>
      )}
    </section>

    <!-- 最近の記事 -->
    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest">Recent Posts</h2>
        <a href="/blog" class="text-xs text-[var(--accent)] hover:underline">すべて見る →</a>
      </div>
      {recentPosts.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {recentPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
              image={post.data.image}
              categories={post.data.categories}
              tags={post.data.tags}
            />
          ))}
        </div>
      ) : (
        <p class="text-sm text-[var(--text-muted)]">記事がありません。</p>
      )}
    </section>
  </div>
</BaseLayout>
