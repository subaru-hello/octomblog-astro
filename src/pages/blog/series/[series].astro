---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/home/ArticleCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  const seriesSet = new Set<string>();
  posts.forEach((post) => post.data.series?.forEach((s) => seriesSet.add(s)));

  return Array.from(seriesSet).map((series) => ({
    params: { series },
    props: {
      series,
      posts: posts
        .filter((p) => p.data.series?.includes(series))
        .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf()),
    },
  }));
}

const { series, posts } = Astro.props;
---

<BaseLayout title={series}>
  <div class="max-w-4xl mx-auto">
    <div class="mb-8">
      <a
        href="/blog"
        class="flex items-center gap-1.5 text-xs text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors mb-4"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
        Blog
      </a>
      <div class="flex items-center gap-2 mb-1">
        <span class="text-xl">📚</span>
        <h1 class="text-2xl font-bold text-[var(--text-primary)]">{series}</h1>
      </div>
      <p class="text-sm text-[var(--text-secondary)]">{posts.length}件の記事</p>
    </div>

    <ol class="space-y-3 mb-10">
      {posts.map((post, i) => (
        <li class="flex items-start gap-3">
          <span class="text-sm text-[var(--text-muted)] mt-0.5 w-6 shrink-0 text-right">{i + 1}.</span>
          <a
            href={`/blog/${post.id}`}
            class="flex-1 group"
          >
            <div class="p-3 rounded-lg border border-[var(--border)] bg-[var(--bg-secondary)] hover:border-[var(--accent)] transition-colors">
              <p class="text-sm font-medium text-[var(--text-primary)] group-hover:text-[var(--accent)] leading-snug mb-1">
                {post.data.title}
              </p>
              {post.data.description && (
                <p class="text-xs text-[var(--text-muted)] line-clamp-1">{post.data.description}</p>
              )}
              <time class="text-xs text-[var(--text-muted)] mt-1 block">
                {post.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </div>
</BaseLayout>
