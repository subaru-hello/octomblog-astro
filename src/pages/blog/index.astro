---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/home/ArticleCard.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// タグ一覧（件数付き）
const tagCount: Record<string, number> = {};
posts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCount[tag] = (tagCount[tag] ?? 0) + 1;
  });
});
const topTags = Object.entries(tagCount)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12);

// シリーズ一覧（件数付き）
const seriesCount: Record<string, number> = {};
posts.forEach((post) => {
  post.data.series?.forEach((s) => {
    seriesCount[s] = (seriesCount[s] ?? 0) + 1;
  });
});
const allSeries = Object.entries(seriesCount).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Blog">
  <div class="max-w-4xl mx-auto">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-[var(--text-primary)] mb-1">Blog</h1>
      <p class="text-sm text-[var(--text-secondary)]">{posts.length}件の記事</p>
    </div>

    <!-- シリーズフィルター -->
    {allSeries.length > 0 && (
      <div class="mb-6">
        <h2 class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider mb-2">シリーズ</h2>
        <div class="flex flex-wrap gap-2">
          {allSeries.map(([name, count]) => (
            <a
              href={`/blog/series/${encodeURIComponent(name)}`}
              class="inline-flex items-center gap-1.5 px-3 py-1 text-xs rounded-full border border-[var(--border)] text-[var(--text-secondary)] bg-[var(--bg-secondary)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors"
            >
              📚 {name} <span class="text-[var(--text-muted)]">{count}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- タグフィルター -->
    {topTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        <a
          href="/blog"
          class="px-3 py-1 text-xs rounded-full border border-[var(--accent)] text-[var(--accent)] bg-[var(--bg-secondary)]"
        >
          すべて
        </a>
        {topTags.map(([tag, count]) => (
          <a
            href={`/blog/tags/${tag}`}
            class="px-3 py-1 text-xs rounded-full border border-[var(--border)] text-[var(--text-secondary)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors"
          >
            #{tag} <span class="text-[var(--text-muted)]">{count}</span>
          </a>
        ))}
      </div>
    )}

    <!-- 記事グリッド -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {posts.map((post) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.id}
          image={post.data.image}
          categories={post.data.categories}
          tags={post.data.tags}
        />
      ))}
    </div>
  </div>
</BaseLayout>
