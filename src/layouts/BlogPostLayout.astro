---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/blog/TOC.astro';
import TagBadge from '../components/blog/TagBadge.astro';
import ViewCounter from '../components/blog/ViewCounter.astro';
import SpeechButton from '../components/blog/SpeechButton.astro';
import SeriesWidget from '../components/blog/SeriesWidget.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: { depth: number; slug: string; text: string }[];
}

const { post, headings } = Astro.props;
const { title, description, date, author, authorEmoji, tags, categories, image } = post.data;

const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const speechText = description ? `${title}。${description}` : title;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(`/${image}`, Astro.site) : new URL('/images/whoami/avatar.jpg', Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description ?? '',
  datePublished: date.toISOString(),
  author: {
    '@type': 'Person',
    name: author ?? 'subaru',
    url: Astro.site?.origin,
  },
  image: ogImage.toString(),
  url: canonicalURL.toString(),
  keywords: tags,
};
---

<BaseLayout title={title} description={description} image={image} noContainer ogType="article" publishedTime={date.toISOString()}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex gap-8">
      <!-- 左: TOC (デスクトップのみ) -->
      <aside class="hidden lg:block w-56 shrink-0">
        <div class="sticky top-24">
          <a href="/blog" class="flex items-center gap-1.5 text-xs text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
            一覧に戻る
          </a>
          <TOC headings={headings} />
        </div>
      </aside>

      <!-- 中央: 記事本文 -->
      <article class="min-w-0 flex-1 max-w-3xl">
        <!-- ヘッダー -->
        <header class="mb-8">
          {image && (
            <img
              src={`/${image}`}
              alt={title}
              class="w-full aspect-[16/9] object-cover rounded-xl mb-6"
              onerror="this.style.display='none'"
            />
          )}

          <!-- タグ -->
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mb-4">
              {tags.map((tag) => (
                <TagBadge tag={tag} href={`/blog/tags/${tag}`} />
              ))}
            </div>
          )}

          <h1 class="text-2xl font-bold text-[var(--text-primary)] leading-snug mb-3">
            {authorEmoji && <span class="mr-1">{authorEmoji}</span>}{title}
          </h1>

          <!-- メタ情報: 著者 / 日付 / 閲覧数 / 読み上げ -->
          <div class="flex flex-wrap items-center gap-3 text-xs text-[var(--text-muted)]">
            <span>{author ?? 'subaru'}</span>
            <span>·</span>
            <time datetime={date.toISOString()}>{formattedDate}</time>
            <span>·</span>
            <ViewCounter slug={post.id} />
            <SpeechButton text={speechText} />
          </div>
        </header>

        <!-- シリーズ（本文より上、ヘッダー直下） -->
        {post.data.series && post.data.series.length > 0 && (
          <div class="mb-6 flex flex-wrap gap-2">
            {post.data.series.map((s) => (
              <a
                href={`/blog/series/${encodeURIComponent(s)}`}
                class="inline-flex items-center gap-1.5 text-xs px-3 py-1 rounded-full border border-[var(--accent)] text-[var(--accent)] bg-[var(--bg-secondary)] hover:bg-[var(--accent)] hover:text-white transition-colors"
              >
                📚 {s}
              </a>
            ))}
          </div>
        )}

        <!-- 本文 -->
        <div class="prose prose-sm max-w-none
          prose-headings:text-[var(--text-primary)]
          prose-p:text-[var(--text-primary)]
          prose-a:text-[var(--accent)]
          prose-strong:text-[var(--text-primary)]
          prose-code:text-[var(--accent)]
          prose-code:bg-[var(--bg-secondary)]
          prose-code:px-1
          prose-code:py-0.5
          prose-code:rounded
          prose-code:before:content-none
          prose-code:after:content-none
          prose-hr:border-[var(--border)]
          prose-blockquote:border-[var(--accent)]
          prose-blockquote:text-[var(--text-secondary)]
          prose-li:text-[var(--text-primary)]
        ">
          <slot />
        </div>

        <!-- シリーズ内の他の記事 -->
        <SeriesWidget post={post} />
      </article>
    </div>
  </div>
</BaseLayout>
