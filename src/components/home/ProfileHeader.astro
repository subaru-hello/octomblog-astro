---
const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/subaru-hello',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z"/></svg>`,
  },
  {
    label: 'Zenn',
    href: 'https://zenn.dev/subaru_hello',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 88 88" fill="currentColor"><path d="M0 0h88v88H0z" fill="none"/><path d="M19.8 75.7h13.7c.5 0 1-.3 1.3-.7L62.4 15c.2-.4-.1-.9-.6-.9H48.2c-.5 0-1 .3-1.3.7L19.3 74.8c-.2.4.1.9.5.9zm48.3 0h13.7c.5 0 .8-.5.6-.9L56.7 38.1c-.2-.4-.8-.4-1 0L44.2 58.6c-.2.4-.2.8 0 1.2l13.4 15.3c.2.4.8.6 1.3.6H68.1z"/></svg>`,
  },
  {
    label: 'X (Twitter)',
    href: 'https://x.com/247Subaru',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.258 5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
];
---

<div class="flex flex-col items-center text-center py-12 gap-5">
  <!-- アバター -->
  <div class="relative">
    <img
      src="/images/whoami/avatar.jpg"
      alt="subaru-hello"
      width="96"
      height="96"
      class="w-24 h-24 rounded-full object-cover border-2 border-[var(--border)]"
    />
  </div>

  <!-- 名前・bio -->
  <div class="flex flex-col gap-1">
    <h1 class="text-xl font-bold text-[var(--text-primary)]">subaru-hello</h1>
    <p class="text-sm text-[var(--text-secondary)]">Web Application Engineer</p>
    <p class="text-sm text-[var(--text-muted)]">Tokyo, Japan · CyberAgent · ex-GMO</p>
  </div>

  <!-- SNS リンク -->
  <div class="flex items-center gap-3">
    {socials.map(({ label, href, icon }) => (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={label}
        class="p-2 rounded-lg text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-secondary)] transition-colors"
        set:html={icon}
      />
    ))}
  </div>
</div>
