---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { series } = post.data;

if (!series || series.length === 0) return;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const seriesGroups = series.map((s) => ({
  name: s,
  posts: allPosts
    .filter((p) => p.data.series?.includes(s))
    .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf()),
}));
---

<div class="mt-10 border-t border-[var(--border)] pt-8">
  {seriesGroups.map(({ name, posts }) => (
    <div class="mb-6">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-base">📚</span>
        <a
          href={`/blog/series/${encodeURIComponent(name)}`}
          class="text-sm font-semibold text-[var(--text-primary)] hover:text-[var(--accent)] transition-colors"
        >
          {name}
        </a>
        <span class="text-xs text-[var(--text-muted)] bg-[var(--bg-secondary)] px-2 py-0.5 rounded-full">
          {posts.length}件
        </span>
      </div>
      <ol class="space-y-2 pl-1">
        {posts.map((p, i) => (
          <li class="flex items-start gap-2.5">
            <span class="text-xs text-[var(--text-muted)] mt-1 w-4 shrink-0">{i + 1}.</span>
            {p.id === post.id ? (
              <span class="text-sm font-semibold text-[var(--accent)]">
                {p.data.title}
              </span>
            ) : (
              <a
                href={`/blog/${p.id}`}
                class="text-sm text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors leading-snug"
              >
                {p.data.title}
              </a>
            )}
          </li>
        ))}
      </ol>
    </div>
  ))}
</div>
