---
interface Props {
  tag: string;
  href?: string;
}
const { tag, href } = Astro.props;
---

{href ? (
  <a
    href={href}
    class="inline-block text-xs px-2.5 py-0.5 rounded-full border border-[var(--border)] text-[var(--text-secondary)] bg-[var(--bg-secondary)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors"
  >
    #{tag}
  </a>
) : (
  <span class="inline-block text-xs px-2.5 py-0.5 rounded-full border border-[var(--border)] text-[var(--text-secondary)] bg-[var(--bg-secondary)]">
    #{tag}
  </span>
)}
