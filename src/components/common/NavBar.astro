---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/docs', label: 'Docs' },
];

const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-[var(--border)] bg-[var(--bg-primary)]/80 backdrop-blur-sm">
  <nav class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="font-bold text-[var(--text-primary)] hover:text-[var(--accent)] transition-colors text-sm">
      octomblog
    </a>

    <div class="flex items-center gap-1">
      {navItems.map(({ href, label }) => {
        const isActive = href === '/'
          ? pathname === '/'
          : pathname.startsWith(href);
        return (
          <a
            href={href}
            class={`px-3 py-1.5 rounded-md text-sm transition-colors ${
              isActive
                ? 'text-[var(--accent)] bg-[var(--bg-secondary)]'
                : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-secondary)]'
            }`}
          >
            {label}
          </a>
        );
      })}
      <!-- 検索ボタン -->
      <a
        href="/search"
        aria-label="検索"
        class={`p-2 rounded-lg transition-colors ${
          pathname === '/search'
            ? 'text-[var(--accent)] bg-[var(--bg-secondary)]'
            : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-secondary)]'
        }`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </a>
      <div class="ml-1">
        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>
